{
  "name": "angular-21",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --watch=false --configuration coverage",
    "coverage:open": "serve coverage/angular-21 --listen 4201 --no-port-switching",
    "reports:refresh": "npm run test:coverage && npm run e2e",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:vrt": "VRT=1 playwright test",
    "e2e:vrt:ui": "VRT=1 playwright test --ui",
    "e2e:vrt:update": "VRT=1 playwright test --update-snapshots",
    "prestorybook": "npm run reports:refresh",
    "storybook": "ng run angular-21:storybook",
    "prebuild-storybook": "npm run reports:refresh",
    "build-storybook": "ng run angular-21:build-storybook"
  },
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@fontsource/material-icons": "^5.2.7",
    "date-fns": "^4.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-devkit/core": "^21.2.0",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@compodoc/compodoc": "^1.2.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/addon-onboarding": "^10.3.0",
    "@storybook/angular": "^10.3.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "storybook": "^10.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
